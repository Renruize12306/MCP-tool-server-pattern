%%{init: {'theme': 'base', 'flowchart': {'padding': 30, 'nodeSpacing': 20, 'rankSpacing': 30}, 'themeVariables': { 'primaryColor': '#E8F4FD', 'primaryBorderColor': '#2196F3', 'lineColor': '#546E7A', 'textColor': '#263238', 'fontSize': '13px'}}}%%

graph TD
    C1["<b>AI Agents / IDE Extensions</b><br/>Any MCP-compatible client"]

    subgraph MCP["MCP Tool Server — Thin Protocol Adapter"]
        direction TB
        TOOLS["<b>Tool Layer</b><br/>Typed contracts, input validation,<br/>pagination cursor management"]
        TRANS["<b>Request Translation</b><br/>MCP tool call → HTTP request<br/>HTTP response → MCP result"]
        ERR["<b>Error Handling</b><br/>HTTP status → MCP error codes<br/>Request ID correlation"]
        TOOLS --> TRANS --> ERR
    end

    subgraph BACKEND["Backend Service — REST API"]
        direction LR
        API["API Endpoints<br/>search, list, get, health"]
        ENGINE["Domain Engine<br/>e.g. Zoekt, Elasticsearch,<br/>document store"]
        KV["Pagination State<br/>Key-value store with TTL"]
        API --> ENGINE
        API --> KV
    end

    DEPLOY["<b>Deployment Modes</b><br/>───────────────────<br/>Local: stdio, no auth, localhost backend<br/>Cloud: HTTP+SSE, OAuth2 + cloud-native auth<br/>───────────────────<br/>AWS: Cognito + IAM SigV4<br/>Azure: Entra ID + Managed Identity"]

    C1 -- "MCP Protocol<br/>stdio (local) / HTTP+SSE (cloud)" --> TOOLS
    ERR -- "HTTP + auth" --> API

    style MCP fill:#F3E5F5,stroke:#9C27B0,stroke-width:2px,color:#4A148C
    style BACKEND fill:#FFF3E0,stroke:#FF9800,stroke-width:2px,color:#E65100

    classDef clientStyle fill:#E8F4FD,stroke:#2196F3,stroke-width:2px,color:#0D47A1
    classDef mcpStyle fill:#E1BEE7,stroke:#9C27B0,stroke-width:1px,color:#4A148C
    classDef beStyle fill:#FFE0B2,stroke:#FF9800,stroke-width:1px,color:#E65100
    classDef deployStyle fill:#E8F5E9,stroke:#4CAF50,stroke-width:2px,color:#1B5E20

    class C1 clientStyle
    class TOOLS,TRANS,ERR mcpStyle
    class API,ENGINE,KV beStyle
    class DEPLOY deployStyle
